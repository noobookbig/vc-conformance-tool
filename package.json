{
  "name": "vc-conformance-test",
  "version": "0.1.0",
  "private": true,
  "description": "OID4VCI / OID4VP 1.0 conformance test webapp for the Thailand VC ecosystem",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch apps/web/src/server.ts",
    "start": "node --import tsx apps/web/src/server.ts",
    "build": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash ops/smoke/run.sh",
    "lint": "tsc -p apps/web/tsconfig.json --noEmit",
    "v2": "node --import tsx apps/conformance-v2/src/cli.ts",
    "v2:run": "node --import tsx apps/conformance-v2/src/cli.ts run",
    "v2:parse": "node --import tsx apps/conformance-v2/src/cli.ts parse",
    "v2:test": "vitest run apps/conformance-v2/test",
    "v2:lint": "tsc -p apps/conformance-v2/tsconfig.json --noEmit",
    "v2:web:dev": "npm --prefix apps/conformance-v2/web run dev",
    "v2:web:build": "npm --prefix apps/conformance-v2/web run build",
    "v2:web:test": "npm --prefix apps/conformance-v2/web run test",
    "v2:web:lint": "npm --prefix apps/conformance-v2/web run lint",
    "v2:web:e2e": "playwright test --config apps/conformance-v2/web/playwright.config.ts",
    "v2:smoke": "node --import tsx scripts/v2-smoke.ts"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/static": "^8.0.4",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "jose": "^5.9.6",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
