{
  "name": "vc-conformance-test",
  "version": "0.1.0",
  "private": true,
  "description": "OID4VCI / OID4VP 1.0 conformance test webapp for the Thailand VC ecosystem",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch apps/web/src/server.ts",
    "start": "node --import tsx apps/web/src/server.ts",
    "build": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash ops/smoke/run.sh",
    "lint": "tsc -p apps/web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/static": "^8.0.4",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "jose": "^5.9.6",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
